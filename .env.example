# Configurações do Banco de Dados PostgreSQL
POSTGRES_DB=GLE
POSTGRES_USER=sysdba
POSTGRES_PASSWORD=wildfire
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Configurações do Backend Rails
RAILS_ENV=development
RAILS_PORT=3005
JWT_SECRET_KEY=your_jwt_secret_key_here

# Configurações do Frontend Angular
ANGULAR_PORT=4005

# URL da API para o Frontend
API_URL=http://localhost:3005/api

# Integração com geosiap-contas (autenticação)
# SECRET_KEY_BASE deve ser o mesmo valor usado pelo geosiap-contas
SECRET_KEY_BASE=your_secret_key_base_from_geosiap_contas
LOGIN_FRONTEND_URL=http://localhost:4201
LOGIN_BACKEND_URL=http://localhost:3002

